{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "token.place desktop",
  "version": "0.1.0",
  "identifier": "place.token.desktop",
  "build": {
    "beforeDevCommand": "python3 -m http.server 1420 --directory ..",
    "beforeBuildCommand": "",
    "frontendDist": "..",
    "devUrl": "http://localhost:1420",
    "features": [
      "app"
    ]
  },
  "app": {
    "windows": [
      {
        "title": "token.place desktop MVP",
        "width": 1000,
        "height": 820
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
