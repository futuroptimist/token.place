# Deprecated Sugarkube Helm bundle definition for the token.place relay.
# Canonical Sugarkube staging/prod deployments now use the OCI chart
# oci://ghcr.io/futuroptimist/charts/tokenplace and the app-specific command:
#   just tokenplace-oci-deploy env=staging tag=main-REPLACE_SHORTSHA
# This file remains only as a historical local bundle example.
RELEASE=tokenplace
CHART=oci://ghcr.io/futuroptimist/charts/tokenplace
VALUES_FILE=/opt/sugarkube/helm-values/token-place-values.yaml
NAMESPACE=tokenplace
WAIT_TARGETS=deployment.apps/tokenplace
NOTES=Deprecated local bundle example; prefer Sugarkube tokenplace-oci-deploy with GHCR artifacts.
